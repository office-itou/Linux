		"62 D#  R#  S#  bluetooth                       when_required   bluez                       Includes_bluetooth_devices_support                                                                      "
		"71 --  R#  S#  prefixdevname                   -               -                           -                                                                                                       "
		"71 --  R#  S#  prefixdevname-tools             -               -                           -                                                                                                       "
		"80 D#  --  --  cms                             when_required   -                           -                                                                                                       "
		"80 D#  R#  S#  lvmmerge                        when_required   -                           Merges_lvm_snapshots                                                                                    "
