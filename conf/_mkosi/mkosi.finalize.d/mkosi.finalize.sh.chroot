		"90 D#  R#  S#  dmsquash-live-ntfs              when_required   fuse3,ntfs-3g               SquashFS_images_located_in_NTFS_filesystems                                                             "
		"90 D+  R+  S+  kernel-modules                  always          -                           kernel_modules_for_root_filesystems_and_other_boot-time_devices                                         "
		"90 D+  R+  S+  kernel-modules-extra            always          -                           extra_out-of-tree_kernel_modules                                                                        "
		"90 D+  R+  S+  kernel-network-modules          when_required   -                           Includes_and_loads_kernel_modules_for_network_devices                                                   "
		"90 D+  R+  S+  livenet                         when_required   -                           Fetch_live_updates_for_SquashFS_images                                                                  "
		"90 D#  R#  S#  lvm                             always          lvm2                        LVM_devices                                                                                             "
		"90 D#  R#  S#  mdraid                          always          mdadm                       kernel_module_for_md_raid_cluster,_mdadm                                                                "
		"90 D#  R#  S#  multipath                       always          multipath-tools             multipath_devices                                                                                       "
		"90 --  R#  S#  numlock                         when_required   -                           -                                                                                                       "
		"90 D#  R#  S#  nvdimm                          when_required   ndctl                       non-volatile_DIMM_devices                                                                               "
		"90 D+  R+  S+  overlayfs                       when_required   -                           kernel_module_for_overlayfs                                                                             "
		"90 D#  R#  S#  overlay-root                    -               -                           overlay-root                                                                                            "
		"90 D#  R#  S#  ppcmac                          when_required   -                           thermal_for_PowerPC                                                                                     "
		"90 D#  R#  S#  qemu                            when_required   -                           kernel_modules_to_boot_inside_qemu                                                                      "
		"90 D#  R#  S#  qemu-net                        always          -                           Includes_network_kernel_modules_for_QEMU_environment                                                    "
		"91 D#  R#  S#  crypt-gpg                       when_required   gnupg                       GPG_for_crypto_operations_and_SmartCards_(may_requires_GPG_keys)                                        "
		"91 D#  R#  S#  crypt-loop                      when_required   -                           encrypted_loopback_devices_(symmetric_key)                                                              "
		"91 D#  R#  S#  fido2                           when_required   -                           fido2                                                                                                   "
		"91 D#  R#  S#  pcsc                            when_required   -                           Adds_support_for_PCSC_Smart_cards                                                                       "
		"91 D#  R#  S#  pkcs11                          when_required   -                           Includes_PKCS#11_libraries                                                                              "
		"91 D#  R#  S#  tpm2-tss                        when_required   tpm2-tools                  Adds_support_for_TPM2_devices                                                                           "
		"91 D#  --  --  zipl                            when_required   -                           zipl                                                                                                    "
		"95 D#  R#  S#  cifs                            always          cifs-utils                  CIFS,_cifs-utils                                                                                        "
		"95 D#  --  --  dasd                            when_required   -                           dasd                                                                                                    "
		"95 D#  --  --  dasd_mod                        when_required   -                           dasd_mod                                                                                                "
		"95 D#  --  --  dasd_rules                      -               -                           -                                                                                                       "
		"95 D#  --  --  dcssblk                         when_required   -                           dcssblk                                                                                                 "
		"95 D#  R#  S#  debug                           when_required   -                           debug_features                                                                                          "
		"95 D#  R#  S#  fcoe                            always          -                           Adds_support_for_Fibre_Channel_over_Ethernet_(FCoE)                                                     "
		"95 D#  R#  S#  fcoe-uefi                       always          -                           Adds_support_for_Fibre_Channel_over_Ethernet_(FCoE)_in_EFI_mode                                         "
		"95 D#  R#  S#  fstab-sys                       always          -                           Arranges_for_arbitrary_partitions_to_be_mounted_before_rootfs                                           "
		"95 --  R#  S#  hwdb                            when_required   -                           -                                                                                                       "
		"95 D#  R#  S#  iscsi                           always          open-iscsi                  Adds_support_for_iSCSI_devices                                                                          "
		"95 D#  R#  S#  lunmask                         always          -                           Masks_LUN_devices_to_select_only_ones_which_required_to_boot                                            "
		"95 D#  R#  S#  nbd                             always          nbd                         kernel_module_for_Network_Block_Device,_nbd                                                             "
		"95 D#  R#  S#  nfs                             always          nfs-utils                   kernel_module_for_NFS,_nfs-utils                                                                        "
		"95 D#  R#  S#  nvmf                            always          nvme-cli,jq                 Adds_support_for_NVMe_over_Fabrics_devices                                                              "
		"95 D#  --  --  qeth_rules                      -               -                           -                                                                                                       "
		"95 D#  R#  S#  resume                          always          -                           resume_from_low-power_state                                                                             "
		"95 D+  R+  S+  rootfs-block                    always          -                           mount_block_device_as_rootfs                                                                            "
		"95 --  R#  S#  squash-erofs                    when_required   -                           -                                                                                                       "
		"95 --  R#  S#  squash-squashfs                 when_required   -                           -                                                                                                       "
		"95 D+  R+  S+  ssh-client                      when_required   openssh                     Includes_ssh_and_scp_clients                                                                            "
		"95 D#  R#  S#  terminfo                        always          -                           Includes_a_terminfo_file                                                                                "
		"95 D+  R+  S+  udev-rules                      always          -                           Includes_udev_and_some_basic_rules                                                                      "
		"95 D#  R#  S#  virtfs                          when_required   -                           virtual_filesystems_(9p)                                                                                "
		"95 D#  R#  S#  virtiofs                        always          -                           virtiofs                                                                                                "
		"95 D#  --  --  zfcp                            when_required   -                           -                                                                                                       "
		"95 D#  --  --  zfcp_rules                      -               -                           -                                                                                                       "
		"95 D#  --  --  znet                            when_required   -                           -                                                                                                       "
		"96 D#  R#  S#  securityfs                      when_required   -                           mount_securityfs_early                                                                                  "
		"97 D#  R#  S#  biosdevname                     always          biosdevname                 BIOS_network_device_renaming                                                                            "
		"97 D#  R#  S#  masterkey                       when_required   -                           masterkey_that_can_be_used_to_decrypt_other_keys_and_keyutils                                           "
		"97 --  R#  S#  systemd-emergency               when_required   -                           -                                                                                                       "
		"98 D+  R+  S+  dracut-systemd                  when_required   -                           Base_systemd_dracut_module                                                                              "
		"98 D#  R#  S#  ecryptfs                        when_required   -                           kernel_module_for_ecryptfs_(stacked_cryptographic_filesystem)                                           "
		"98 D#  R#  S#  integrity                       when_required   -                           Extended_Verification_Module_and_ima-evm-utils                                                          "
		"98 D+  R+  S+  pollcdrom                       when_required   -                           polls_CD-ROM                                                                                            "
		"98 D#  R#  S#  selinux                         when_required   -                           selinux_policy                                                                                          "
		"98 D#  R#  S#  syslog                          when_required   rsyslog                     Includes_syslog_capabilites                                                                             "
		"98 D#  R#  S#  usrmount                        always          -                           mounts_/usr                                                                                             "
		"99 D+  R+  S+  base                            always          -                           Base_module_with_required_utilities                                                                     "
		"99 D#  R#  S#  busybox                         when_required   busybox                     busybox                                                                                                 "
		"99 --  R#  S#  earlykdump                      -               -                           -                                                                                                       "
		"99 D#  R#  S#  fs-lib                          always          -                           filesystem_tools_(including_fsck.*_and_mount)                                                           "
		"99 D#  R#  S#  img-lib                         when_required   -                           Includes_various_tools_for_decompressing_images                                                         "
		"99 --  R#  S#  kdumpbase                       -               -                           -                                                                                                       "
		"99 D#  R#  S#  memstrack                       always          memstrack                   Includes_memstrack_for_memory_usage_monitoring                                                          "
		"99 --  R#  S#  microcode_ctl-fw_dir_override   -               -                           -                                                                                                       "
		"99 --  R#  S#  openssl                         -               -                           -                                                                                                       "
		"99 --  R#  S#  shell-interpreter               when_required   -                           -                                                                                                       "
		"99 D#  R#  S#  shutdown                        always          -                           Sets_up_hooks_to_run_on_shutdown                                                                        "
		"99 --  R#  S#  squash                          when_required   squashfs-tools              -                                                                                                       "
		"99 --  R#  S#  squash-lib                      when_required   -                           -                                                                                                       "
		"99 D#  R#  S#  uefi-lib                        when_required   -                           Includes_UEFI_tools                                                                                     "
	)
	if [[ -e /usr/lib/modules/. ]]; then
		declare -r    __KDIR="/usr/lib/modules"
	else
		declare -r    __KDIR="/lib/modules"
	fi
	declare -r    __KRNL="$(ls "${__KDIR:?}")"
	declare -r    __ARCH="${__KRNL##*[-.]}"
	declare -r    __VERS="${__KRNL%[-.]"${__ARCH}"}"
	declare       __DIST=""				# D:debian/ubuntu, R:rhel/..., S:opensuse/suse
	declare -a    __ADDS=()
	declare -a    __OMIT=()
	declare -a    __OPTN=()
	declare -a    __LIST=()				# work variable
	declare -i    __RTCD=0				# return code
	declare -i    I=0

	__DIST=""
	case "${DISTRIBUTION:-}" in
		debian      | \
		ubuntu      ) __DIST="D";;
		fedora      | \
		centos      | \
		alma        | \
		rocky       | \
		miracle     ) __DIST="R";;
		opensuse    ) __DIST="S";;
#		kali        ) ;;
#		arch        ) ;;
#		mageia      ) ;;
#		rhel-ubi    ) ;;
#		rhel        ) ;;
#		openmandriva) ;;
#		azure       ) ;;
#		custom      ) ;;
		*           ) __DIST="";;
	esac

	__ADDS=()
	__OMIT=()
	for I in "${!__MODS[@]}"
	do
		read -r -a __LIST < <(echo "${__MODS[I]}")
		__WORK=""
		case "${__DIST}" in
			"${__LIST[1]:0:1}") __WORK="${__LIST[1]:1:1}";;
			"${__LIST[2]:0:1}") __WORK="${__LIST[2]:1:1}";;
			"${__LIST[3]:0:1}") __WORK="${__LIST[3]:1:1}";;
			*                 ) continue;;
		esac
		case "${__WORK:-}" in
			"+") __ADDS+=("${__LIST[4]}");;	# common add
			"-") __OMIT+=("${__LIST[4]}");;	# "      omit
			*  ) ;;
		esac
	done
	readonly __ADDS
	readonly __OMIT

	__OPTN=(\
		--stdlog 3 \
		--force \
		--no-hostonly \
		--no-early-microcode \
		--nomdadmconf \
		--nolvmconf \
		--gzip \
		${__KRNL:+--kver "${__KRNL}"} \
		${__ADDS[*]:+--add "${__ADDS[*]}"} \
		${__OMIT[*]:+--omit "${__OMIT[*]}"} \
		--filesystems "ext4 fat exfat isofs squashfs udf xfs" \
		--force-drivers "nvme" \
	)
	readonly __OPTN

	if ! command -v dracut > /dev/null 2>&1; then
		fnMsgout "${_PROG_NAME:-}" "caution" "not exist: dracut"
	else
		if ! dracut "${__OPTN[@]}"; then
			__RTCD="$?"
			fnMsgout "${_PROG_NAME:-}" "failed" "dracut ${__OPTN[*]}"
			fnMsgout "${_PROG_NAME:-}" "start" "${__SHEL}"
			"${__SHEL:?}"
			fnMsgout "${_PROG_NAME:-}" "complete" "${__SHEL}"
			exit "${__RTCD}"
		fi
		if [[ ! -e "/boot/vmlinuz-${__KRNL}" ]]; then
			cp -a "${__KDIR}/${__KRNL}/vmlinuz" "/boot/vmlinuz-${__KRNL}"
		fi
	fi

	# --- complete ------------------------------------------------------------
	fnMsgout "${_PROG_NAME:-}" "complete" "[${__FUNC_NAME}]"
	unset '_DBGS_FAIL[${#_DBGS_FAIL[@]}-1]'
	_DBGS_FAIL=("${_DBGS_FAIL[@]}")
	fnDbgparameters
#	unset __FUNC_NAME
}

# -----------------------------------------------------------------------------
# descript: finalize preset service
#   input :            : unused
#   output:   stdout   : message
#   return:            : unused
function fnMkosi_finalize_service() {
	declare -r    __FUNC_NAME="${FUNCNAME[0]}"
	_DBGS_FAIL+=("${__FUNC_NAME:-}")
	fnMsgout "${_PROG_NAME:-}" "start" "[${__FUNC_NAME}]"

	# --- 00-user-custom.preset -----------------------------------------------
	declare       __LINE=""
	declare -a    __LIST=()
	declare -r    __PATH="/etc/systemd/system-preset/00-user-custom.preset"
	mkdir -p "${__PATH%/*}"
	# --- mask ----------------------------------------------------------------
	: > "${__PATH:?}"
	for __LINE in \
		"disable chronyd.service" \
		"disable avahi-daemon.service" \
		"disable nmb.service" \
		"disable nmbd.service" \
		"disable winbind.service" \
		"disable wicked.service" \
		"disable systemd-networkd.service" \
		"enable  apparmor.service" \
		"enable  auditd.service" \
		"enable  firewalld.service" \
		"enable  clamav-freshclam.service" \
		"enable  clamav-daemon.service" \
		"enable  NetworkManager.service" \
		"enable  systemd-resolved.service" \
		"enable  dnsmasq.service" \
		"enable  systemd-timesyncd.service" \
		"enable  open-vm-tools.service" \
		"enable  vmtoolsd.service" \
		"enable  ssh.service" \
		"enable  sshd.service" \
		"enable  apache2.service" \
		"enable  httpd.service" \
		"enable  smb.service" \
		"enable  smbd.service"
	do
		read -r -a __LIST < <(echo "${__LINE}")
		if [[ ! -e "/lib/systemd/system/${__LIST[1]}"     ]] \
		&& [[ ! -e "/usr/lib/systemd/system/${__LIST[1]}" ]]; then
			fnMsgout "${_PROG_NAME:-}" "not found" "${__LIST[1]}"
			continue
		fi
		fnMsgout "${_PROG_NAME:-}" "${__LIST[0]}" "${__LIST[1]}"
		printf "%-8.8s%s\n" "${__LIST[0]}" "${__LIST[1]}" >> "${__PATH:?}"
	done 
	unset __LINE __LIST

	# --- complete ------------------------------------------------------------
	fnMsgout "${_PROG_NAME:-}" "complete" "[${__FUNC_NAME}]"
	unset '_DBGS_FAIL[${#_DBGS_FAIL[@]}-1]'
	_DBGS_FAIL=("${_DBGS_FAIL[@]}")
	fnDbgparameters
#	unset __FUNC_NAME
}

# *** main section ************************************************************

# -----------------------------------------------------------------------------
# descript: main routine
#   input :            : unused
#   output:   stdout   : message
#   return:            : unused
function fnMain() {
	declare -r    __FUNC_NAME="${FUNCNAME[0]}"
	_DBGS_FAIL+=("${__FUNC_NAME:-}")
	fnMsgout "${_PROG_NAME:-}" "start" "[${__FUNC_NAME}]"

	# --- initial setup -------------------------------------------------------
	fnMkosi_initialize					# initialize

	# --- main processing -----------------------------------------------------
	fnMkosi_finalize_locale				# finalize locale
	fnMkosi_finalize_userenv			# finalize user environment
	fnMkosi_finalize_setup				# finalize setup
	fnMkosi_finalize_dracut				# finalize dracut
	fnMkosi_finalize_service			# finalize preset service

	# --- complete ------------------------------------------------------------
	fnMsgout "${_PROG_NAME:-}" "complete" "[${__FUNC_NAME}]"
	unset '_DBGS_FAIL[${#_DBGS_FAIL[@]}-1]'
	_DBGS_FAIL=("${_DBGS_FAIL[@]}")
	fnDbgparameters
#	unset __FUNC_NAME
}

	# --- debug output redirection --------------------------------------------
	if set -o | grep "^xtrace\s*on$"; then
		exec 2>&1
	fi

	# --- debug output --------------------------------------------------------
	if [[ -n "${_DBGS_FLAG:-}" ]]; then
		fnDbgout "command line" \
			"debug,_COMD_LINE=[${_COMD_LINE:-}]"
	fi

	# --- start ---------------------------------------------------------------
	declare -i    __time_start=0
	declare -i    __time_end=0
	declare -i    __time_elapsed=0

	__time_start=$(date +%s)
	fnMsgout "${_PROG_NAME:-}" "start" "$(date -d "@${__time_start}" +"%Y/%m/%d %H:%M:%S" || true)"

	# --- main processing -----------------------------------------------------
	fnMain

	# --- complete ------------------------------------------------------------
	__time_end=$(date +%s)
	__time_elapsed=$((__time_end - __time_start))
	fnMsgout "${_PROG_NAME:-}" "complete" "$(date -d "@${__time_end}" +"%Y/%m/%d %H:%M:%S" || true)"
	fnMsgout "${_PROG_NAME:-}" "elapsed" "$(printf "%dd%02dh%02dm%02ds\n" $((__time_elapsed/86400)) $((__time_elapsed%86400/3600)) $((__time_elapsed%3600/60)) $((__time_elapsed%60)) || true)"
	unset __time_start __time_end __time_elapsed

	exit 0

# ### eof #####################################################################
